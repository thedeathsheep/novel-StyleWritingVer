# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# AI provider: openai | google | aihubmix | siliconflow (default: openai)
# AI_PROVIDER=openai

# --- OpenAI (when AI_PROVIDER=openai or unset) ---
# https://platform.openai.com/account/api-keys
OPENAI_API_KEY=
# Optional: custom base URL (e.g. proxy)
# OPENAI_BASE_URL=

# --- Google Gemini (when AI_PROVIDER=google) ---
# https://aistudio.google.com/apikey
# GOOGLE_GEMINI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=  # used by @ai-sdk/google if set

# --- AIHubMix (when AI_PROVIDER=aihubmix) ---
# https://docs.aihubmix.com
# AIHUBMIX_API_KEY=

# --- SiliconFlow (when AI_PROVIDER=siliconflow) ---
# https://cloud.siliconflow.com
# SILICONFLOW_API_KEY=

# Optional: override default chat/embedding model per provider
# AI_CHAT_MODEL=
# AI_EMBEDDING_MODEL=

# OPTIONAL: Vercel Blob (for uploading images)
# Get your Vercel Blob credentials here: https://vercel.com/docs/storage/vercel-blob/quickstart#quickstart
BLOB_READ_WRITE_TOKEN=

# OPTIONAL: Vercel KV (for ratelimiting)
# Get your Vercel KV credentials here: https://vercel.com/docs/storage/vercel-kv/quickstart#quickstart
KV_REST_API_URL=
KV_REST_API_TOKEN=
